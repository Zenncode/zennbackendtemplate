{
  "compilerOptions": {
    "module": "Node16",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2021",
    "sourceMap": true,
    "rootDir": "./app",
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": true,
    "moduleResolution": "Node16",
    "types": ["node"]
  },
  "include": ["app/**/*"],
  "exclude": ["node_modules", "dist"]
}
