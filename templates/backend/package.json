{
  "name": "zenntechinc-backend",
  "version": "1.0.0",
  "description": "Backend template for ZENNTECHINC APIs",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "dev": "nodemon",
    "dev:server": "ts-node --files -r tsconfig-paths/register app/server.ts",
    "start:debug": "node --inspect -r ts-node/register -r tsconfig-paths/register app/server.ts",
    "start:prod": "node dist/server.js",
    "lint": "eslint \"{app,tests}/**/*.ts\"",
    "lint:fix": "eslint \"{app,tests}/**/*.ts\" --fix",
    "format": "prettier --write \"app/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "husky",
    "test": "jest --runInBand --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --runInBand --coverage",
    "test:e2e": "jest --config ./tests/jest-e2e.json --runInBand --passWithNoTests"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.3",
    "redis": "^4.7.1",
    "socket.io": "^4.8.3",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.14.12",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "@typescript-eslint/parser": "^8.0.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.4",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "app/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
